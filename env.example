# ── Variables de entorno — NUNCA commitear el .env real ──
# Copiar este archivo a .env y completar los valores

# ── Firebase (solo las públicas van al cliente) ──
VITE_FIREBASE_API_KEY=your_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=micanton-cr.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=micanton-cr
VITE_FIREBASE_STORAGE_BUCKET=micanton-cr.appspot.com
VITE_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
VITE_FIREBASE_APP_ID=your_app_id

# ── App config ──
VITE_APP_NAME=MiCantón.cr
VITE_APP_ENV=development

# ── Secretos — SOLO en Cloud Functions / Vercel Environment Variables ──
# ANTHROPIC_API_KEY=sk-ant-...   ← NUNCA en el cliente
# FIREBASE_ADMIN_KEY=...          ← NUNCA en el cliente
